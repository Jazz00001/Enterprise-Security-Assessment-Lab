*_rsa
*_rsa.pub
*_ed25519
*_ed25519.pub
*.ssh

# ============================================================

# 🏢 5. Active Directory / Credential Dumping Raw Outputs

# ============================================================

# Do not commit raw dumps or live credential material.

# Screenshot evidence is allowed if redacted.

hashes.txt
hash.txt
ntlm_hashes.txt
ntlmv2_hashes.txt
kerberoast_hashes.txt
asrep_hashes.txt
dcsync-raw.txt
raw-dcsync.txt
secretsdump.txt
secretsdump-output.txt
samdump.txt
ntds.dit
SYSTEM
SECURITY
SAM
*.kirbi
*.ccache
*.ticket
*.kirbi.b64

# BloodHound raw collection files may expose full lab relationships.

# Keep only redacted screenshots unless you intentionally sanitize data.

bloodhound*.json
*_BloodHound.zip
BloodHound*.zip
SharpHound*.zip
*sharphound*.json
neo4j-data/
graph.db/

# ============================================================

# 🌐 6. Web VAPT Raw Sensitive Outputs

# ============================================================

# Screenshots can be committed after redaction.

# Raw dumps and exploitation files should not be committed.

sqlmap_output/
.output/
dump/
dumps/
loot/
exfil/
webshell.php
shell.php
cmd.php
upload-shell.php
reverse-shell.php
php-reverse-shell.php
*.sqlite
*.sqlite3
database-dump.sql
db-dump.sql
users-dump.txt
password-dump.txt
cracked-passwords.txt
john.pot
hashcat.potfile

# ============================================================

# 🔌 7. API Security Sensitive Files

# ============================================================

# Postman collections are okay only if tokens are replaced with variables.

# Postman environments often contain live secrets, so they are blocked.

*.postman_environment.json
postman-environment*.json
postman_environment*.json
insomnia-secrets.json
oauth-tokens.json
jwt-token.txt
jwt.txt
bearer-token.txt
refresh-token.txt
access-token.txt
authorization-header.txt

# ============================================================

# ☁️ 8. Cloud Tool Session / Report Files with Account Data

# ============================================================

# Pacu can store credentials/session data.

.pacu/
pacu.db
pacu.sqlite
pacu-session*
pacu_sessions/
sessions/

# ScoutSuite raw reports can include account/resource identifiers.

# Keep screenshots only, or sanitize reports before committing.

scoutsuite-report/
scoutsuite-results/
ScoutSuite-results/
scout-report/
scout-results/

# CloudGoat local state and generated files

.cloudgoat/
cloudgoat/
CloudGoat/
cg-*.json
terraform.tfstate.d/

