*.tmp
*.temp
*.bak
*.swp
*.swo
temp/
tmp/
.cache/
.cache/*
history.txt
command-history.txt
terminal-history.txt

# ============================================================

# 🖥️ 13. Operating System and Editor Files

# ============================================================

.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini
.vscode/
